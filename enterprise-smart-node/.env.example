# --- Enterprise Smart Node config ---

# Display name for this node
NODE_NAME=default

# URI prefix for all entities created on this node.
# Neutral default; override per deployment/tenant, e.g. enox://acme.example/team-a
NODE_URI_PREFIX=enox://local/default

# HTTP port
PORT=3700

# Storage paths
KUZU_DB_PATH=./data/enox.db
SQLITE_PATH=./data/enox-meta.sqlite

# public = read-only API, no auth; private = bearer-token auth required for writes
NODE_MODE=private

# Federation peers: "prefix1=url1,prefix2=url2" (optional)
NODE_PEERS=

# Legacy single shared token (optional). Prefer per-user tokens issued via the
# admin GUI / user store. If set, this token authenticates as the built-in
# 'admin' user. Leave empty to require per-user tokens only.
AUTH_TOKEN=

# Bootstrap admin token: on first start, if no users exist, a user named
# ADMIN_USER is created with this token so you can log into the admin GUI
# and issue more tokens. Change it before exposing the node.
ADMIN_USER=admin
ADMIN_TOKEN=

# --- Optional LLM features (OFF by default) ---
#
# The node is a PURE DATA LAYER: store / query / traverse / local-ONNX embed /
# auth / admin all run with NO LLM and NO `claude` CLI installed.
#
# A few features are LLM-dependent and OPT-IN:
#   - free-text note→graph ingestion (POST /api/ingest)
#   - LLM-judged dedup link suggestions (the dedup worker still does its
#     deterministic embedding-based merges without an LLM)
#
# To enable them, set the master switch AND supply a command. The command
# receives the prompt on STDIN and must print the completion to STDOUT.
# {model} is substituted with the requested model name (e.g. "sonnet"/"haiku").
# The operator is responsible for installing whatever the command needs.
#
# LLM_INGEST_ENABLED=1
# LLM_CMD=claude -p --model {model} --output-format text
LLM_INGEST_ENABLED=
LLM_CMD=
